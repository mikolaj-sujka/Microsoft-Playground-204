{
  "Application": {
    "Name": "Microsoft Playground",
    "Mode": "Production",
    "Region": "westeurope",
    "Version": "1.0.0"
  },
  "StorageAccount": {
    "AccountName": "playgroundstorage",
    "AvatarContainerName": "avatars"
  },
  "AzureAppConfiguration": {
    "Enabled": true,
    "Label": "Production",
    "SentinelKey": "TestApp:Settings:Sentinel",
    "FeatureFlagCacheExpirationSeconds": 30
  },
  "Observability": {
    "SelfTestBaseUrl": "",
    "DependencySimulator": {
      "TimeoutSeconds": 15
    }
  },
  "OpenTelemetry": {
    "ServiceName": "MicrosoftPlayground.Api",
    "Logs": {
      "IncludeScopes": true,
      "IncludeFormattedMessage": true,
      "ParseStateValues": true
    }
  },
  "Scalar": {
    "Enabled": true,
    "EnabledOutsideDevelopment": false,
    "EndpointPrefix": "/scalar",
    "OpenApiRoutePattern": "/openapi/{documentName}.json",
    "Title": "Microsoft Playground API",
    "ShowSidebar": true,
    "DarkMode": false,
    "HideDownloadButton": false,
    "HideTestRequestButton": false,
    "DynamicBaseServerUrl": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "OpenTelemetry": {
      "LogLevel": {
        "Default": "Information",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "ApplicationInsights": {
    "EnableLiveMetrics": true
  }
}
